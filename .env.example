BOT_TOKEN=
# Админы в одной строке через запятую (запятая в конце не мешает), например: 7600749840,9999999999
ADMIN_IDS=
# Пауза перед перезапуском после необработанного сбоя (сек.)
BOT_RESTART_DELAY_SEC=5
# Через запятую; при 429 — ротация по ключам
DEEPSEEK_API_KEYS=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Пусто = берётся DEEPSEEK_MODEL (ниже)
DEEPSEEK_ANSWER_MODEL=
DEEPSEEK_MODEL=deepseek-chat
# Выход: меньше токенов — быстрее и короче ответ (потолок см. app/ai_client.py)
DEEPSEEK_ANSWER_MAX_TOKENS=1400
DEEPSEEK_ANSWER_TIMEOUT=75
DEEPSEEK_PROXY_URL=
TELEGRAM_PROXY_URL=
HTTP_PROXY_URL=
DATABASE_PATH=bot.db
# Платежи Telegram: токен провайдера из BotFather; пусто — только текст и /grant_sub
PAYMENT_PROVIDER_TOKEN=
# 100 ₽ = 10000 копеек; 600 ₽ = 60000 копеек
SUBSCRIPTION_PRICE_KOPECKS=10000
SUBSCRIPTION_YEAR_PRICE_KOPECKS=60000

# ЮKassa (Telegram Payments): для некоторых магазинов требуется чек (54‑ФЗ).
# Укажите систему налогообложения (1..6) и ставку НДС (1..6).
# 0 = не отправлять provider_data (использовать как есть).
# vat_code: 1=без НДС, 2=0%, 3=10%, 4=20%, 5=10/110, 6=20/120 (см. ЮKassa).
YOOKASSA_TAX_SYSTEM_CODE=0
YOOKASSA_VAT_CODE=1
